{
  "name"              : "valkyrja/phpcsfixer",
  "type"              : "project",
  "description"       : "PHP CS Fixer for the Valkyrja Project.",
  "homepage"          : "https://www.valkyrja.io/",
  "keywords"          : [
    "ci",
    "phpcsfixer",
    "valkyrja"
  ],
  "license"           : "MIT",
  "authors"           : [
    {
      "name"  : "Melech Mizrachi",
      "email" : "melechmizrachi@gmail.com"
    }
  ],
  "require"           : {
    "php"                       : ">=8.4",
    "friendsofphp/php-cs-fixer" : "^3.95.1"
  },
  "autoload"          : {
    "psr-4" : {
      "Valkyrja\\Fixer\\" : "src/Fixer"
    }
  },
  "autoload-dev"      : {
    "psr-4" : {
      "Valkyrja\\Fixer\\Tests\\" : "tests/Tests"
    }
  },
  "scripts"           : {
    "phpcsfixer"                              : "cd .github/ci/phpcsfixer && composer fix",
    "phpcsfixer-check"                        : "cd .github/ci/phpcsfixer && composer check",
    "phpcsfixer-outdated-check"               : "cd .github/ci/phpcsfixer && composer install && composer outdated --direct --minor-only",
    "phpcsfixer-outdated-check-major-release" : "cd .github/ci/phpcsfixer && composer install && composer outdated --direct",
    "phpcsfixer-composer-update"              : "cd .github/ci/phpcsfixer && composer update"
  },
  "minimum-stability" : "dev",
  "prefer-stable"     : true
}
